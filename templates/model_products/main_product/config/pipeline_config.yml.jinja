# This file acts as the central registry for a given "model product," defining references
# to all the reusable building blocks - images, components, and pipelines — that
# constitute your MLOps workflows.

# For more details on this file, please see docs/config/mdk_pipeline_config_usage.md

lite: {{ lite | lower }}

images:

  standard:
    artifact: "standard:latest"
    build_config_dir: "model_products/main_product/images/standard"

  # Uncomment if you intend to use Bring-Your-Own-Container (BYOC) - Dockerfile version
  # byoc:
  #   artifact: "byoc:latest"
  #   build_config_dir: "model_products/main_product/images/byoc"

pipelines:

  training_pipeline:
    description: Pipeline to be used for training a model.
    function: pipeline
    module_path: model_products/main_product/pipelines/training_pipeline/pipeline.py

  batch_inference_pipeline:
    description: Pipeline to be used for running inference for a trained model.
    function: pipeline
    module_path: model_products/main_product/pipelines/batch_inference_pipeline/pipeline.py

  deployment_pipeline:
    description: Pipeline to be used to deploy a trained model.
    function: pipeline
    module_path: model_products/main_product/pipelines/deployment_pipeline/pipeline.py

components:

  log_config_to_experiment:
    description: "Logging config values to Vertex Experiments."
    function: log_config_to_experiment
    module_path: model_products/main_product/components/log_config_to_experiment/component.py
    image_artifact: "standard:latest"
  preprocess:
    description: "Data cleaning, feature engineering."
    function: preprocess
    module_path: model_products/main_product/components/preprocess/component.py
    image_artifact: "standard:latest"
  optimize_hyperparameters:
    description: "Hyperparameter optimization"
    function: optimize_hyperparameters
    module_path: model_products/main_product/components/optimize_hyperparameters/component.py
    image_artifact: "standard:latest"
  train:
    description: "Model training workflow"
    function: train
    module_path: model_products/main_product/components/train/component.py
    image_artifact: "standard:latest"
    # # These values below are for overriding default resources:
    # cpu: "8"
    # mem: "64G"
  evaluate:
    description: "Model evaluation workflow"
    function: evaluate
    module_path: model_products/main_product/components/evaluate/component.py
    image_artifact: "standard:latest"
  upload_to_model_registry:
    description: "Upload a trained model to Model Registry"
    function: upload_to_model_registry
    module_path: model_products/main_product/components/upload_to_model_registry/component.py
    image_artifact: "standard:latest"
  batch_predict:
    description: "Batch Prediction"
    function: batch_predict
    module_path: model_products/main_product/components/batch_predict/component.py
    image_artifact: "standard:latest"
  model_monitoring:
    description: "Setup Model Monitoring jon for a Vertex AI Model"
    function: model_monitoring
    module_path: model_products/main_product/components/model_monitoring/component.py
    image_artifact: "standard:latest"
  model_deployment:
    description: "Model deployment workflow"
    function: model_deployment
    module_path: model_products/main_product/components/model_deployment/component.py
    image_artifact: "standard:latest"

  # # Bring-Your-Own-Container (BYOC) example scenarios:
