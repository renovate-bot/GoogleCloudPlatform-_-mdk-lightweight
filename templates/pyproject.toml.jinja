[project]
name = "{{project_slug}}"
# This is the Python project version, not a model version that would go involve
#   the extended model registry.
version = "0.0.1"
description = "Add your description here"
readme = "README.md"
requires-python = ">=3.11"
dependencies = [
    "copier>=9.8.0",
    "bigframes>=2.21.0",
    "db-dtypes>=1.4.3",
    "docker>=7.1.0",
    "google-cloud-aiplatform>=1.101.0",
    "google-cloud-bigquery>=3.36.0",
    "google-cloud-pipeline-components>=2.21.0",
    "kfp>=2.13.0",
    "matplotlib>=3.10.6",
    "numpy>=2.3.2",
    "pandas>=2.3.1",
    "pandas-gbq>=0.29.2",
    "pillow>=11.3.0",
    "python-dotenv>=1.1.1",
    "pyyaml>=6.0.2",
    "requests>=2.32.4",
    "scikit-learn>=1.7.1",
    "shap>=0.48.0",
    "setuptools>=80.9.0",
    "xgboost<=3.0.2",
    "numba>=0.57.0",
    "bigframes>=2.21.0",
    "db-dtypes>=1.4.3",
    "pyOpenSSL"

]

[project.scripts]
mdk = "mdk.cli.main:main"

[build-system]
requires = [
    "setuptools",
]
build-backend = "setuptools.build_meta"

# Bring along sample CSV files for examples like the Dry Beans dataset.
[tools.setuptools.package.find]
where = ["src"]

[tool.setuptools.package-data]
examples = ["xgb_example/data/*.csv"]


[dependency-groups]
dev = [
    "pre-commit>=4.2.0",
    "pytest>=8.4.1",
    "ruff>=0.12.1",
]



[[tool.uv.index]]
name = "pypi"
url = "https://pypi.org/simple"
