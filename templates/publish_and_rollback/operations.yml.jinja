# Optional: Global metadata about this deployment configuration
metadata:
  config_version: "1.0"
  description: "Declarative model deployment configurations for the '{{project_slug}}' repository."
  author: "Data Science Team"

# Options for Model Inference Reference:
# - "latest", it will use the last created model for "model_name"
# - "primary", it will use the primary model for "model_name" and the deployment_environment
# - semantic version, it will use that specific model_semantic_version (e.g. 0.1.1)
# - gcs path, it will use that specific gcs directory containing the model (e.g. gs://trained-model/)

# --- Deployment Operations Section ---
# This is a list allowing multiple operations to be defined in one config file.
# The GitHub Action will iterate through this list and execute each operation.
# This is broken up by environment as well, which corresponds to the github
# repo source branch.
environments:
  # --------------------- DEV ENVIRONMENT ---------------------
  dev:
    api_settings:
      expanded_model_registry_endpoint: "{{expanded_model_registry_endpoint}}"
      project_id: "{{project_id_dev}}"
      region: "{{region}}"
      deployment_environment: "dev"
    operations:

    ###########################################
    #                                         #
    #   Uncomment to publish a new champion   #
    #                                         #
