# Read in our .env file, if it exists.
MDK_AR_URL = $(error Please set MDK_AR_URL in your .env file)
-include .env

# Variables:
############

PYTHON := @PYTHON@
srcdir := @srcdir@
pkg := mdk

py_packages := $(shell find $(srcdir)/src -type d)

version := $(shell \
$(PYTHON) -c "import tomllib; \
f=open('pyproject.toml', 'rb'); \
p=tomllib.load(f); \
print(p['project']['version']); \
")


# Phony rules:
##############

.PHONY: default all clean distclean release pushnexus tag wheel

default: all

all: wheel

clean:
	@echo "Removing Emacs artifacts..."
	@for d in . $(py_packages) ; do \
		$(RM) -v $$d/*~ $$d/\#~ ; \
	done
	@echo "Removing __pycache__ directories..."
	@for d in $(shell find $(srcdir)/src -type d -name __pycache__) ; do \
		printf "%s" "$(RM) -rv " ; \
		$(RM) -rv $$d ; \
	done

distclean: clean
	for d in \
		build \
		dist \
		src/$(pkg).egg-info \
		src/$(pkg)/__pycache__ \
		autom4te.cache \
	; do \
		$(RM) -rv $$d ; \
	done
	$(RM) -v config.status config.log autoscan.log
	$(RM) -v MANIFEST.in

# The login and password are presumed to be fetched dynamically via gcloud token
publish: wheel
	@echo "Uploading to Artifact Registry: $(MDK_AR_URL)"
	$(PYTHON) -m twine upload \
		--repository-url $(MDK_AR_URL) \
		--username "__token__" \
		--password "$(shell gcloud auth print-access-token)" \
		dist/*
	@echo "PLEASE NOTE: Remember to increment the package version in pyproject.toml as your next task."

release: wheel tag publish

tag:
	git tag -a "v$(version)" -m "Release v$(version)"


wheel: MANIFEST.in
	uv build


# Explicit rules:
#################

# The following generates a MANIFEST.in file, which ensures build scripts are
#   included in the .tgz source distribution.

MANIFEST.in: Makefile
	> $@ ;
	echo "### THIS FILE IS AUTOMATICALLY GENERATED IN Makefile.in. ###" >> $@
	echo "### DO NOT EDIT BY HAND ###" >> $@
	echo "" >> $@
	echo "include Makefile.in" >> $@
	echo "include configure.ac" >> $@
	echo "include configure" >> $@
